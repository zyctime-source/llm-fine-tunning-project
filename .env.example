# 数据流水线：HF 下载 + Qwen 翻译（复制为 .env 后填写）
# ---------------------------------------------------------------------------
# 路径
# ---------------------------------------------------------------------------
DATA_ROOT=./data
BRAINSTORM_RAW_DIR=./data/raw/brainstorm_vicuna_10k
GENERAL_RAW_DIR=./data/raw/general_mixed
TRANSLATED_JSONL_PATH=./data/processed/brainstorm_vicuna_10k_zh.jsonl
TRANSLATION_CHECKPOINT_PATH=./data/processed/translation_checkpoint.json
# 翻译默认读取 train 分片；若使用自定义文件，设置绝对或相对路径
# BRAINSTORM_SOURCE_JSONL=./data/raw/brainstorm_vicuna_10k/train.jsonl

# ---------------------------------------------------------------------------
# Hugging Face（可选：gated 数据集或提高限额）
# ---------------------------------------------------------------------------
# 只读 token 即可减少「未登录请求」限流；gated 模型/数据集必填。
# 在 https://huggingface.co/settings/tokens 创建后填入：
# HF_TOKEN=hf_xxx
# HF_HOME=

# 中国大陆下载加速（第三方镜像，与官方同步可能有分钟级延迟；仅作下载用）
# 文档与说明：https://hf-mirror.com/
# 在**当前终端**或 `.env` 中设置（Transformers / huggingface_hub 会读取）：
# HF_ENDPOINT=https://hf-mirror.com

# ---------------------------------------------------------------------------
# brainstorm_vicuna_10k
# ---------------------------------------------------------------------------
BRAINSTORM_DATASET_REPO=DevQuasar/brainstorm_vicuna_10k
# BRAINSTORM_DATASET_REVISION=

# 脑暴验证导出（python -m data_pipeline export-brainstorm-val）：训练 head 之后取英文窗，并按 id 对齐译稿
# BRAINSTORM_TRAIN_HEAD_N=5000
# BRAINSTORM_VAL_EXPORT_N=3000
# BRAINSTORM_VAL_EN_JSONL=./data/raw/brainstorm_vicuna_10k/validation_en.jsonl
# BRAINSTORM_VAL_ZH_JSONL=./data/processed/brainstorm_vicuna_10k_zh_validation.jsonl
# BRAINSTORM_VALIDATION_META_JSON=./data/processed/brainstorm_validation_meta.json
# 设为 1 时：验证窗内任一 id 在译稿中不存在则命令失败
# BRAINSTORM_VAL_REQUIRE_FULL_ZH=0

# ---------------------------------------------------------------------------
# 通用混合：英文 Alpaca 类 + 中文指令类。
# 默认各抽 2000（共 4000），再从每种语言尾部切出各 GENERAL_VAL_N/2 条作验证，
# 落盘 general_mixed_train.jsonl（3000）与 general_mixed_validation.jsonl（1000）。
# 设 GENERAL_VAL_N=0 则只写一个 general_mixed.jsonl（兼容旧行为）。
# 中文默认数据集可在 HF 上按字段自动归一化；若解析条数偏少，请更换 GENERAL_ZH_DATASET_REPO
# 或设置 GENERAL_ZH_DATASET_CONFIG 指定子配置名。
# ---------------------------------------------------------------------------
GENERAL_TOTAL_N=4000
GENERAL_SEED=42
GENERAL_VAL_N=1000
GENERAL_EN_DATASET_REPO=tatsu-lab/alpaca
GENERAL_EN_DATASET_SPLIT=train
GENERAL_EN_SAMPLE_N=2000
# GENERAL_EN_DATASET_REVISION=
# GENERAL_EN_DATASET_CONFIG=

GENERAL_ZH_DATASET_REPO=FreedomIntelligence/evol-instruct-chinese
GENERAL_ZH_DATASET_SPLIT=train
GENERAL_ZH_SAMPLE_N=2000
# GENERAL_ZH_DATASET_REVISION=
# GENERAL_ZH_DATASET_CONFIG=

# ---------------------------------------------------------------------------
# 阿里云 DashScope（OpenAI 兼容模式）— Qwen-Max / Qwen-Plus
# 文档：https://help.aliyun.com/zh/model-studio/developer-reference/use-qwen-by-calling-api
# ---------------------------------------------------------------------------
DASHSCOPE_API_KEY=
DASHSCOPE_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TRANSLATE_MODEL=qwen-max
# TRANSLATE_MODEL=qwen-plus

# 仅翻译 train 分片导出文件中的行；断点续跑会跳过输出 JSONL 中已存在的 id
TRANSLATE_SPLIT=train
# 调试时可限制最多翻译条数（留空表示不限制）
# TRANSLATE_MAX_ITEMS=20

# 终端进度：每完成 N 条新译打印一行（另：第 1 条、达到 TRANSLATE_MAX_ITEMS 时也会打印）
TRANSLATE_LOG_EVERY_N=5

TRANSLATE_REQUEST_INTERVAL_SEC=0.35
TRANSLATE_MAX_TOKENS=8192
TRANSLATE_TEMPERATURE=0.2
TRANSLATE_TIMEOUT_SEC=120
